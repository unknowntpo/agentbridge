#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
if [[ -L "$SOURCE" ]]; then
  TARGET="$(readlink "$SOURCE")"
  if [[ "$TARGET" = /* ]]; then
    SOURCE="$TARGET"
  else
    SOURCE="$(cd "$(dirname "$SOURCE")" && pwd)/$TARGET"
  fi
fi

SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"

if [[ -f "$SCRIPT_DIR/../dist/cli.js" ]]; then
  exec bun "$SCRIPT_DIR/../dist/cli.js" "$@"
fi

if [[ -f "$SCRIPT_DIR/../src/cli.ts" ]]; then
  exec bun "$SCRIPT_DIR/../src/cli.ts" "$@"
fi

echo "agentbridge: built CLI not found. Reinstall the package or run 'bun run build' in a source checkout." >&2
exit 1
