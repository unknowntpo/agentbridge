DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_TOKEN=
# Trusted workspace catalog entries use id:path pairs, for example:
# AGENTBRIDGE_TRUSTED_WORKSPACES=repo:~/repo,agentbridge:~/repo/unknowntpo/agentbridge
AGENTBRIDGE_SQLITE_PATH=.agentbridge/state.db
AGENTBRIDGE_CODEX_COMMAND=codex
AGENTBRIDGE_CODEX_ARGS=
AGENTBRIDGE_GEMINI_COMMAND=gemini
AGENTBRIDGE_GEMINI_ARGS=
AGENTBRIDGE_DEFAULT_PROVIDER=codex
AGENTBRIDGE_CODEX_HOME=~/.codex
# Must remain loopback unless AgentBridge later supports encrypted app-server transport.
AGENTBRIDGE_CODEX_APP_SERVER_HOST=127.0.0.1
AGENTBRIDGE_CODEX_APP_SERVER_PORT=4591
AGENTBRIDGE_CODEX_APP_SERVER_APPROVAL_POLICY=never
AGENTBRIDGE_DISCORD_MESSAGE_LIMIT=2000
# Required for Discord runtime. Empty means default-deny.
AGENTBRIDGE_ALLOWED_CHANNEL_IDS=
AGENTBRIDGE_DISCORD_SUMMARY_CHANNEL_ID=
AGENTBRIDGE_DISCORD_SUMMARY_MENTION_USER_ID=
AGENTBRIDGE_TRUSTED_WORKSPACES=
