{
  "name": "agentbridge",
  "version": "0.1.0",
  "description": "Self-hosted Discord bridge for local Codex and Gemini CLI sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unknowntpo/agentbridge.git"
  },
  "homepage": "https://github.com/unknowntpo/agentbridge",
  "bugs": {
    "url": "https://github.com/unknowntpo/agentbridge/issues"
  },
  "keywords": [
    "discord",
    "codex",
    "gemini",
    "agent",
    "bun",
    "self-hosted"
  ],
  "type": "module",
  "exports": {},
  "engines": {
    "bun": ">=1.3.13"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agentbridge": "./bin/agentbridge"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/cli.ts --outdir dist --target bun --format esm",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "desktop:dev": "bunx vite --host 127.0.0.1",
    "desktop:build": "bunx vite build",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "start": "bun src/cli.ts",
    "dev": "bun --watch src/cli.ts",
    "test": "bun test test/*.test.ts desktop/src/*.test.ts",
    "test:watch": "bun test --watch test/*.test.ts desktop/src/*.test.ts"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "commander": "^14.0.1",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "ink": "^7.0.1",
    "react": "^19.2.5",
    "react-devtools-core": "^7.0.1",
    "vue": "^3.5.33",
    "ws": "^8.18.3",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/bun": "^1.3.13",
    "@types/node": "^22.14.1",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^5.8.3",
    "vite": "^6.0.0"
  }
}
