{
  "name": "agentbridge",
  "version": "0.1.0",
  "description": "Self-hosted Discord bridge for local Codex and Gemini CLI sessions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/unknowntpo/agentbridge.git"
  },
  "homepage": "https://github.com/unknowntpo/agentbridge",
  "bugs": {
    "url": "https://github.com/unknowntpo/agentbridge/issues"
  },
  "keywords": [
    "discord",
    "codex",
    "gemini",
    "agent",
    "bun",
    "self-hosted"
  ],
  "type": "module",
  "exports": {},
  "engines": {
    "bun": ">=1.3.13"
  },
  "files": [
    "bin",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "agentbridge": "./bin/agentbridge"
  },
  "scripts": {
    "build": "rm -rf dist && bun build ./src/index.ts ./src/cli.ts --outdir dist --target bun --format esm",
    "check": "bunx tsc --noEmit -p tsconfig.json",
    "desktop:dev": "bunx vite --host 127.0.0.1",
    "desktop:build": "bunx vite build",
    "tauri:dev": "bunx tauri dev",
    "tauri:build": "bunx tauri build",
    "start": "bunx tsx src/cli.ts",
    "dev": "bunx tsx watch src/cli.ts",
    "test": "bunx vitest run --config vitest.config.ts",
    "test:watch": "bunx vitest --config vitest.config.ts"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "commander": "^14.0.1",
    "discord.js": "^14.19.3",
    "dotenv": "^16.4.7",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.14.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vite": "^6.0.0",
    "vitest": "^3.1.2"
  }
}
