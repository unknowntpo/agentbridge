{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AgentHub",
  "version": "0.1.0",
  "identifier": "dev.agenthub.desktop",
  "build": {
    "beforeDevCommand": "bun run desktop:dev",
    "beforeBuildCommand": "bun run desktop:build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AgentHub",
        "width": 1440,
        "height": 900,
        "minWidth": 1200,
        "minHeight": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "icon": []
  }
}
